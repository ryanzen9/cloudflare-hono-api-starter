{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM"],
    "types": ["vite/client"],
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [".vitepress/**/*", "**/*.md", "**/*.ts", "**/*.vue"],
  "exclude": [
    "**/openapi.json",
    "**/.agents/**",
    ".vitepress/dist",
    ".vitepress/cache"
  ]
}
