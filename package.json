{
  "name": "cloudflare-workers-openapi",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "deploy": "wrangler deploy",
    "start": "wrangler dev",
    "cf-typegen": "wrangler types",
    "login": "wrangler login",
    "install": "oxlint",
    "lint": "oxlint src/",
    "check": "oxfmt --check . && oxlint src/ && tsc",
    "format": "oxfmt . --write",
    "db:deploy": "wrangler d1 migrations apply drizzle_example --local",
    "db:deploy:remote": "wrangler d1 migrations apply drizzle_example --remote",
    "db:generate": "drizzle-kit generate",
    "docs": "chanfana --output docs/openapi.json src/index.ts"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.4.0",
    "chanfana": "^3.3.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.12",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.94.0"
  }
}
