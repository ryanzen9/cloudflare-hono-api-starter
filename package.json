{
  "name": "cloudflare-hono-api-starter",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "docs": "chanfana --output docs/openapi.json src/index.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "deploy": "wrangler deploy",
    "start": "wrangler dev",
    "cf-typegen": "wrangler types",
    "login": "wrangler login",
    "install": "oxlint",
    "lint": "oxlint src/ test/ examples/ vitest.config.ts",
    "typecheck": "tsc && tsc -p test/tsconfig.json",
    "format": "oxfmt . --write",
    "check": "oxfmt --check . && oxlint src/ test/ examples/ vitest.config.ts && bun run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:deploy": "wrangler d1 migrations apply drizzle_example --local",
    "db:deploy:remote": "wrangler d1 migrations apply drizzle_example --remote",
    "cf-r2:list": "wrangler r2 buckets list",
    "cf-r2:create": "wrangler r2 buckets create cloudflare-hono-api-starter",
    "kv:create": "wrangler kv namespace create cloudflare-hono-api-starter"
  },
  "dependencies": {
    "@cloudflare/ai-chat": "^0.9.3",
    "@hono/zod-openapi": "^1.4.0",
    "agents": "^0.17.4",
    "ai": "^7.0.28",
    "chanfana": "^3.3.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.12",
    "hono-agents": "^3.0.11",
    "workers-ai-provider": "^3.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@types/node": "^25.9.1",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "typescript": "^7.0.2",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.0",
    "wrangler": "^4.111.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "oxfmt",
      "oxlint"
    ],
    "*.{json,jsonc,md,yml,yaml,css,scss,html}": [
      "oxfmt"
    ]
  },
  "packageManager": "bun@1.3.13"
}
