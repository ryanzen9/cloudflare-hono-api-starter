{
  "name": "cloudflare-workers-openapi",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "docs": "chanfana --output docs/openapi.json src/index.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "deploy": "wrangler deploy",
    "start": "wrangler dev",
    "cf-typegen": "wrangler types",
    "login": "wrangler login",
    "install": "oxlint",
    "lint": "oxlint src/",
    "typecheck": "tsc && tsc -p test/tsconfig.json",
    "format": "oxfmt . --write",
    "check": "oxfmt --check . && oxlint src/ test/ vitest.config.ts && bun run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:deploy": "wrangler d1 migrations apply drizzle_example --local",
    "db:deploy:remote": "wrangler d1 migrations apply drizzle_example --remote"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.4.0",
    "chanfana": "^3.3.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.12",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@types/node": "^25.9.1",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "typescript": "^7.0.2",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.0",
    "wrangler": "^4.94.0"
  },
  "packageManager": "bun@1.3.13"
}
